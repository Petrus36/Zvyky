# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string from Neon (or any hosted Postgres)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Secret key used to sign admin JWT tokens — use any long random string
JWT_SECRET="change-this-to-a-long-random-secret-string"


