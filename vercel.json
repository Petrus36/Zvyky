{
  "buildCommand": "npx prisma generate && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 15,
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|favicon\\.ico|favicon\\.svg|favicon.*\\.png|apple-touch-icon\\.png|site\\.webmanifest|images/).*)",
      "destination": "/index.html"
    }
  ]
}
